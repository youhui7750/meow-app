rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // App data (per-user sessions, messages, memory, preferences, experiences)
    // stays open for the demo/test window. Cloud Functions use the Admin SDK,
    // which bypasses these rules regardless.
    match /users/{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 6, 27);
    }

    // Everything else is denied to clients. In particular this covers `config/*`,
    // which holds the rotating Gemini API keys — only the Cloud Functions (Admin
    // SDK) and the project owner (console) may read/write it. NOTE: Firestore
    // rules are OR-combined, so this collection MUST NOT be matched by any
    // broader `allow` rule above — keep app access scoped under `users/`.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
